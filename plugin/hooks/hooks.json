{
  "description": "The Seam's structural nets - mechanism at the discipline-decay points (docs/2026-07-11-seam-design.md). NOTE: scaffolded on the dev machine where the plugin is not installed; validate on first real install (ROADMAP).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/first_of_day.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/sweep_reminder.py\" stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/sweep_reminder.py\" precompact"
          }
        ]
      }
    ]
  }
}
